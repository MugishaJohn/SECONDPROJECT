# Cell 1: Import libraries (Already provided)
import numpy as np
import pandas as pd
from scipy.sparse import csr_matrix
from sklearn.neighbors import NearestNeighbors
import matplotlib.pyplot as plt

# Cell 2: Load data (Already provided)
books_filename = 'books.csv'
ratings_filename = 'ratings.csv'

# Read the data
df_books = pd.read_csv(
    books_filename,
    encoding = "ISO-8859-1",
    sep=";",
    header=0,
    names=['isbn', 'title', 'author']
)
df_ratings = pd.read_csv(
    ratings_filename,
    encoding = "ISO-8859-1",
    sep=";",
    header=0,
    names=['user', 'isbn', 'rating']
)

# Cell 3: Your code here - Data preprocessing and filtering
# Remove users with less than 200 ratings and books with less than 100 ratings
print("Original ratings shape:", df_ratings.shape)

# Count number of ratings per user
user_ratings_count = df_ratings['user'].value_counts()
# Count number of ratings per book
book_ratings_count = df_ratings['isbn'].value_counts()

# Filter users with at least 200 ratings
df_ratings = df_ratings[df_ratings['user'].isin(user_ratings_count[user_ratings_count >= 200].index)]
# Filter books with at least 100 ratings
df_ratings = df_ratings[df_ratings['isbn'].isin(book_ratings_count[book_ratings_count >= 100].index)]

print("Filtered ratings shape:", df_ratings.shape)

# Merge books with ratings to get the complete dataset
df = pd.merge(df_ratings, df_books, on='isbn')

# Create pivot table for user-book ratings
pivot_table = df.pivot_table(index='title', columns='user', values='rating').fillna(0)
print("Pivot table shape:", pivot_table.shape)

# Convert to sparse matrix for efficient computation
book_features = csr_matrix(pivot_table.values)

# Cell 4: Your code here - Build and fit the KNN model
# Create KNN model
model = NearestNeighbors(metric='cosine', algorithm='brute')
model.fit(book_features)

# Cell 5: Your code here - Create the recommendation function
def get_recommends(book_title=""):
    try:
        # Find the index of the book
        book_index = np.where(pivot_table.index == book_title)[0][0]
        
        # Find nearest neighbors
        distances, indices = model.kneighbors(
            book_features[book_index].reshape(1, -1), 
            n_neighbors=6
        )
        
        # Get recommendations (excluding the book itself)
        recommended_books = []
        for i in range(1, len(indices.flatten())):
            recommended_title = pivot_table.index[indices.flatten()[i]]
            distance = distances.flatten()[i]
            recommended_books.append([recommended_title, distance])
        
        # Sort by distance (closest first) and return only top 5
        recommended_books.sort(key=lambda x: x[1])
        
        return [book_title, recommended_books[:5]]
    
    except IndexError:
        return f"Book '{book_title}' not found in the database after filtering."

# Test the function
print(get_recommends("The Queen of the Damned (Vampire Chronicles (Paperback))"))

# Cell 6: Testing cell (Already provided)
# This cell will test your function and should return the expected output
books = get_recommends("Where the Heart Is (Oprah's Book Club (Paperback))")
print(books)
